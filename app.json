{
  "expo": {
    "name": "FloodSense",
    "slug": "floodsense",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/icon.png",
      "backgroundColor": "#0D3B5E",
      "resizeMode": "contain"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.floodsense.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#0D3B5E"
      },
      "package": "com.floodsense.app"
    },
    "plugins": [
      "expo-router"
    ],
    "scheme": "floodsense",
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "af9d6367-2e70-4196-879b-cff920c60986"
      }
    }
  }
}
